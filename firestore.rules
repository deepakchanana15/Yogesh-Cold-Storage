rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // All client-side access is blocked.
    // The Next.js API routes use the Firebase Admin SDK (service account),
    // which bypasses these rules entirely.
    // This prevents any direct browser access to inquiry data.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
